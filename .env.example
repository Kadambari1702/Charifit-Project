# Copy this file to .env for local use (and add real values in your
# hosting provider's dashboard as environment variables for deployment).
# Never commit a real .env file — it's already in .gitignore.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=charifit_db
DB_USER=root
DB_PASSWORD=your_password_here

# Set automatically by most cloud hosts (Render, Railway, Fly.io).
# Only needed locally if you want to test on a non-default port.
PORT=8080
